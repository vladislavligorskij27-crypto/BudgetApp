<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BudgetApp"
             x:Class="BudgetApp.MainPage"
             BackgroundColor="#F4F6F8">

    <ContentPage.BindingContext>
        <local:BudgetViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25" MaximumWidthRequest="500" HorizontalOptions="Center">

            <Label Text="💎 Мой Бюджет" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50" Margin="0,10,0,0" />

            <Border StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#4A00E0" Offset="0, 8" Radius="15" Opacity="0.2" />
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A00E0" Offset="0.0" />
                        <GradientStop Color="#8E2DE2" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="10" Padding="25" HorizontalOptions="Fill">
                    <Label Text="Текущий баланс" FontSize="16" TextColor="#D1D8E0" HorizontalOptions="Center"/>

                    <Label Text="{Binding TotalBalance, StringFormat='{0} BYN'}" FontSize="48" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                        <Label Text="Заполненность бюджета:" FontSize="12" TextColor="#E0E0E0" HorizontalOptions="Center" />
                        <ProgressBar Progress="{Binding ExpenseProgress}" ProgressColor="#FF6B6B" BackgroundColor="#6A1B9A" HeightRequest="8" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" Margin="0,15,0,0">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="Доходы 📈" TextColor="#A8E6CF" FontSize="14" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalIncome, StringFormat='+{0} BYN'}" TextColor="White" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="Расходы 📉" TextColor="#FF8B94" FontSize="14" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalExpense, StringFormat='-{0} BYN'}" TextColor="White" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 15" Stroke="#E1E8EE" BackgroundColor="White" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0, 5" Radius="10" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <Label Text="✍️ Добавить запись" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" />

                    <Entry Placeholder="Название (например: Продукты)" Text="{Binding InputTitle}" BackgroundColor="#F8FAFC" TextColor="#333" />

                    <Picker Title="Выберите категорию" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" BackgroundColor="#F8FAFC" TextColor="#333" />

                    <Entry Placeholder="Сумма (например: 1500,50)" Text="{Binding InputAmount}" Keyboard="Text" BackgroundColor="#F8FAFC" TextColor="#333" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="+ Доход" Command="{Binding AddIncomeCommand}" BackgroundColor="#27AE60" TextColor="White" CornerRadius="10" FontAttributes="Bold" />
                        <Button Grid.Column="1" Text="- Расход" Command="{Binding AddExpenseCommand}" BackgroundColor="#E74C3C" TextColor="White" CornerRadius="10" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                <Label Grid.Column="0" Text="🕒 История операций" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />

                <Button Grid.Column="1" Text="🗑 Очистить всё" Command="{Binding ClearAllCommand}" BackgroundColor="#FFF0F0" TextColor="#E74C3C" FontSize="12" Padding="10,5" HeightRequest="35" CornerRadius="8" />
            </Grid>

            <CollectionView ItemsSource="{Binding Transactions}">
                <CollectionView.EmptyView>
                    <Label Text="Пока ничего нет. Добавьте первую операцию! 🚀" TextColor="Gray" HorizontalOptions="Center" Margin="20" HorizontalTextAlignment="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5,0,5" Padding="15" BackgroundColor="White" Stroke="#F0F2F5" StrokeThickness="1" StrokeShape="RoundRectangle 15">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0, 2" Radius="5" Opacity="0.03" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="15" VerticalOptions="Center">

                                <Label Grid.Column="0" Text="{Binding Icon}" FontSize="28" VerticalOptions="Center" />

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="#333" />
                                    <HorizontalStackLayout Spacing="5">
                                        <Border BackgroundColor="#F0F2F5" Stroke="Transparent" StrokeShape="RoundRectangle 5" Padding="5,2">
                                            <Label Text="{Binding Category}" FontSize="10" TextColor="#666" FontAttributes="Bold" />
                                        </Border>
                                        <Label Text="{Binding FormattedDate}" FontSize="11" TextColor="Gray" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Text="{Binding DisplayAmount}" TextColor="{Binding DisplayColor}" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />

                                <Button Grid.Column="3" Text="❌" BackgroundColor="Transparent" TextColor="Red" FontSize="14" WidthRequest="40" HeightRequest="40" Padding="0" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:BudgetViewModel}}, Path=RemoveTransactionCommand}" 
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>